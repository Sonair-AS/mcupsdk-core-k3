%%{
    isDevelopmentMode = args.common.isDevelopmentMode();
    deviceName = args.utils.getProjectSpecDevice(args.device);
    if(args.device == "am62x")
        deviceName = "AM62x"
    sysCfgVersion = args.utils.getSysCfgVersionProjectSpec();
%%}
{
% if(isDevelopmentMode) {
    "name": "MCU_PLUS_SDK",
    "displayName": "MCU+ SDK",
% } else {
    % if (args.device == "am275x") {
    "name": "`deviceName`_FREERTOS_SDK",
    "displayName": "FreeRTOS SDK for `deviceName`",
    % } else {
    "name": "MCU_PLUS_SDK_`deviceName`",
    "displayName": "MCU+ SDK for `deviceName`",
    % }
% }
    "version": "07.03.01",
    "documentationPath": "../docs",
    "includePaths": [
        "../source",
        "../source/networking/enet/core/sysconfig",
    ],
    "components": [
% if((args.device == "j722s")) {
        "/kernel/dpl",
        "/drivers/drivers",
        "/board/board",
        "/fs/fs",
% }
% if((args.device == "am62x") || (args.device == "am62px")) {
        "/kernel/dpl",
        "/drivers/drivers",
        "/board/board",
        "/fs/fs",
        "/networking/networking",
%}
% if((args.device == "am62ax")) {
        "/kernel/dpl",
        "/drivers/drivers",
        "/board/board",
        "/fs/fs",
        "/security/security",
%if((isDevelopmentMode)){
        "/networking/networking",
% }
% }
% if((args.device == "am275x")) {
        "/kernel/dpl",
        "/drivers/drivers",
        "/board/board",
        "/fs/fs",
        "/networking/networking",
%}
% if((args.device == "am62dx")) {
        "/kernel/dpl",
        "/drivers/drivers",
        "/board/board",
        "/fs/fs",
        "/security/security",
        "/networking/networking",
% }
    ],
    "devices": [
% if((args.device == "am62x") || (isDevelopmentMode)) {
        "AM62x",
        "AM62SIP",
% }
% if((args.device == "am62ax") || (isDevelopmentMode)) {
        "AM62Ax",
% }
% if((args.device == "am62px") || (isDevelopmentMode)) {
        "AM62Px",
% }
% if((args.device == "am275x") || (isDevelopmentMode)) {
        "AM275x",
% }
% if((args.device == "j722s") || (isDevelopmentMode)) {
        "J722S",
% }
% if((args.device == "am62dx") || (isDevelopmentMode)) {
        "AM62D-Q1",
% }
    ],
    "contexts": {
% if((args.device == "am62x") || (isDevelopmentMode)) {
        "AM62x": [
            "m4fss0-0",
            "r5fss0-0",
            "a53ss0-0",
            "a53ss0-1",
            "a53ss1-0",
            "a53ss1-1",
        ],
        "AM62SIP": [
            "m4fss0-0",
            "r5fss0-0",
            "a53ss0-0",
            "a53ss0-1",
            "a53ss1-0",
            "a53ss1-1",
        ],
% }
% if((args.device == "am62ax") || (isDevelopmentMode)) {
        "AM62Ax": [
            "mcu-r5fss0-0",
            "r5fss0-0",
            "c75ss0-0",
            "a53ss0-0",
        ],
% }
% if((args.device == "am62px") || (isDevelopmentMode)) {
        "AM62Px": [
            "mcu-r5fss0-0",
            "wkup-r5fss0-0",
        ],
% }
% if((args.device == "am275x") || (isDevelopmentMode)) {
        "AM275x": [
            "r5fss0-0",
            "r5fss0-1",
            "r5fss1-0",
            "r5fss1-1",
            "c75ss0-0",
            "c75ss1-0",
            "wkup-r5fss0-0",
        ],
% }
% if((args.device == "j722s") || (isDevelopmentMode)) {
        "J722S": [
            "mcu-r5fss0-0",
            "wkup-r5fss0-0",
            "main-r5fss0-0",
            "c75ss0-0",
            "c75ss1-0",
            "a53ss0-0",
            "a53ss0-1",
            "a53ss1-0",
            "a53ss1-1",
            "hsm0-0",
        ],
% }
% if((args.device == "am62dx") || (isDevelopmentMode)) {
        "AM62D-Q1": [
            "mcu-r5fss0-0",
            "r5fss0-0",
            "c75ss0-0",
            "a53ss0-0",
        ],
% }

    },
    "pinmuxUIOptions": {
        "group": "merged",
        "hidePeripheralTab": false,
        "showPinTable": true,
        "showSignals": true,
        "showUsed": true
    },
    "minToolVersion" : "`sysCfgVersion`"
}
