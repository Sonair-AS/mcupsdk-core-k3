$(BUILD_COMBO_SCRUB_dmautils):
	$(MAKE) -C source/drivers/dmautils -f makefile.j722s.$(subst dmautils_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_freertos):
	$(MAKE) -C source/kernel/freertos -f makefile.j722s.$(subst freertos_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_rm_pm_hal):
	$(MAKE) -C source/drivers/device_manager/rm_pm_hal -f makefile.j722s.$(subst rm_pm_hal_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_rm_pm_hal_sbl):
	$(MAKE) -C source/drivers/device_manager/rm_pm_hal/sbl -f makefile.j722s.$(subst rm_pm_hal_sbl_,,$(subst _scrub,,$@)) scrub


