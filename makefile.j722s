# Various Component Targets
BUILD_COMBO_board = board_r5f.ti-arm-clang board_c75x.ti-c7000
BUILD_COMBO_drivers = drivers_mcu-r5f.ti-arm-clang drivers_wkup-r5f.ti-arm-clang drivers_main-r5f.ti-arm-clang drivers_c75ss0-0.ti-c7000 drivers_c75ss1-0.ti-c7000
BUILD_COMBO_self_reset = self_reset_wkup-r5f.ti-arm-clang
BUILD_COMBO_sciclient_direct = sciclient_direct_wkup-r5f.ti-arm-clang
BUILD_COMBO_sciclient_direct_sbl = sciclient_direct_sbl_wkup-r5f.ti-arm-clang
BUILD_COMBO_sciserver = sciserver_wkup-r5f.ti-arm-clang
BUILD_COMBO_dmautils = dmautils_c75ss0-0.ti-c7000 dmautils_c75ss1-0.ti-c7000
BUILD_COMBO_freertos = freertos_r5f.ti-arm-clang freertos_c75x.ti-c7000
BUILD_COMBO_rm_pm_hal = rm_pm_hal_wkup-r5f.ti-arm-clang
BUILD_COMBO_rm_pm_hal_sbl = rm_pm_hal_sbl_wkup-r5f.ti-arm-clang

# Combine all Components
BUILD_COMBO_ALL = $(BUILD_COMBO_board) $(BUILD_COMBO_drivers) $(BUILD_COMBO_self_reset) $(BUILD_COMBO_sciclient_direct) $(BUILD_COMBO_sciclient_direct_sbl) $(BUILD_COMBO_sciserver) $(BUILD_COMBO_dmautils) $(BUILD_COMBO_freertos) $(BUILD_COMBO_rm_pm_hal) $(BUILD_COMBO_rm_pm_hal_sbl)

# Combine all External Components
BUILD_COMBO_EXTERNAL_ALL =

# Combine all Pre-built Components
BUILD_COMBO_PREBUILT_ALL =

# Combine all Private Components
BUILD_COMBO_PRIVATE_ALL =

libs: $(BUILD_COMBO_ALL)

libs-external: $(BUILD_COMBO_EXTERNAL_ALL)

libs-prebuilt: $(BUILD_COMBO_PREBUILT_ALL)

libs-private: $(BUILD_COMBO_PRIVATE_ALL)

$(BUILD_COMBO_board):
	$(MAKE) -C source/board -f makefile.j722s.$(subst board_,,$@) all

$(BUILD_COMBO_drivers):
	$(MAKE) -C source/drivers -f makefile.j722s.$(subst drivers_,,$@) all

$(BUILD_COMBO_self_reset):
	$(MAKE) -C source/drivers/device_manager/self_reset -f makefile.j722s.$(subst self_reset_,,$@) all

$(BUILD_COMBO_sciclient_direct):
	$(MAKE) -C source/drivers/device_manager/sciclient_direct -f makefile.j722s.$(subst sciclient_direct_,,$@) all

$(BUILD_COMBO_sciclient_direct_sbl):
	$(MAKE) -C source/drivers/device_manager/sciclient_direct/sbl -f makefile.j722s.$(subst sciclient_direct_sbl_,,$@) all

$(BUILD_COMBO_sciserver):
	$(MAKE) -C source/drivers/device_manager/sciserver -f makefile.j722s.$(subst sciserver_,,$@) all

$(BUILD_COMBO_dmautils):
	$(MAKE) -C source/drivers/dmautils -f makefile.j722s.$(subst dmautils_,,$@) all

$(BUILD_COMBO_freertos):
	$(MAKE) -C source/kernel/freertos -f makefile.j722s.$(subst freertos_,,$@) all

$(BUILD_COMBO_rm_pm_hal):
	$(MAKE) -C source/drivers/device_manager/rm_pm_hal -f makefile.j722s.$(subst rm_pm_hal_,,$@) all

$(BUILD_COMBO_rm_pm_hal_sbl):
	$(MAKE) -C source/drivers/device_manager/rm_pm_hal/sbl -f makefile.j722s.$(subst rm_pm_hal_sbl_,,$@) all


