	@echo  $(MAKE) -s -f makefile.j722s libs
	@echo  $(MAKE) -s -f makefile.j722s libs-clean # delete's tmp files for current profile
	@echo  $(MAKE) -s -f makefile.j722s libs-scrub # delete's all tmp files and folders for all profiles
