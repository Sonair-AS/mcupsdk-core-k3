BUILD_COMBO_EXTERNAL_ALL =

# Combine all Pre-built Components
BUILD_COMBO_PREBUILT_ALL =

# Combine all Private Components
BUILD_COMBO_PRIVATE_ALL =

libs: $(BUILD_COMBO_ALL)

libs-external: $(BUILD_COMBO_EXTERNAL_ALL)

libs-prebuilt: $(BUILD_COMBO_PREBUILT_ALL)

libs-private: $(BUILD_COMBO_PRIVATE_ALL)

$(BUILD_COMBO_board):
	$(MAKE) -C source/board -f makefile.am275x.$(subst board_,,$@) all

$(BUILD_COMBO_drivers):
	$(MAKE) -C source/drivers -f makefile.am275x.$(subst drivers_,,$@) all

$(BUILD_COMBO_udma):
	$(MAKE) -C source/drivers/udma -f makefile.am275x.$(subst udma_,,$@) all

$(BUILD_COMBO_sciclient_direct):
	$(MAKE) -C source/drivers/device_manager/sciclient_direct -f makefile.am275x.$(subst sciclient_direct_,,$@) all

$(BUILD_COMBO_sciclient_direct_sbl):
	$(MAKE) -C source/drivers/device_manager/sciclient_direct/sbl -f makefile.am275x.$(subst sciclient_direct_sbl_,,$@) all

$(BUILD_COMBO_sciserver):
	$(MAKE) -C source/drivers/device_manager/sciserver -f makefile.am275x.$(subst sciserver_,,$@) all

$(BUILD_COMBO_self_reset):
	$(MAKE) -C source/drivers/device_manager/self_reset -f makefile.am275x.$(subst self_reset_,,$@) all

$(BUILD_COMBO_dhrystone_benchmark):
	$(MAKE) -C source/dhrystone_benchmark -f makefile.am275x.$(subst dhrystone_benchmark_,,$@) all

$(BUILD_COMBO_freertos_fat):
	$(MAKE) -C source/fs/freertos_fat -f makefile.am275x.$(subst freertos_fat_,,$@) all

$(BUILD_COMBO_nortos):
	$(MAKE) -C source/kernel/nortos -f makefile.am275x.$(subst nortos_,,$@) all

$(BUILD_COMBO_freertos):
	$(MAKE) -C source/kernel/freertos -f makefile.am275x.$(subst freertos_,,$@) all

$(BUILD_COMBO_rm_pm_hal):
	$(MAKE) -C source/drivers/device_manager/rm_pm_hal -f makefile.am275x.$(subst rm_pm_hal_,,$@) all


