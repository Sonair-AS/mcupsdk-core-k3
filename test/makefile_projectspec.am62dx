help:
	@echo  Notes,
	@echo  - Use -j to invoke parallel builds
	@echo  - Use PROFILE=Debug or PROFILE=Release [default] to build in Debug or Release profile
	@echo  .
	@echo  Overall build targets,
	@echo  ======================
	@echo  $(MAKE) -s -f makefile_projectspec.am62dx help
	@echo  .
	@echo  $(MAKE) -s -f makefile_projectspec.am62dx [export all clean]
	@echo  .
	@echo  export = export projectspec to CCS project in the folder ./ccs_projects/,
	@echo           export MUST be called once before 'all' or 'clean'
	@echo  all    = build the previously exported projectspecs
	@echo  clean  = clean the previously exported projectspecs
	@echo  .
	@echo  Example ProjectSpec build targets,
	@echo  ==================================
	@echo  $(MAKE) -s -C ../source/networking/enet/core/examples/tsn/lldp_cpsw_app/am62dx-evm/mcu-r5fss0-0_freertos/ti-arm-clang -f makefile_projectspec [export all clean]
	@echo  $(MAKE) -s -C ../source/networking/enet/core/examples/tsn/avtplistener_app/am62dx-evm/mcu-r5fss0-0_freertos/ti-arm-clang -f makefile_projectspec [export all clean]
